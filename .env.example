# Copy to .env.local (web) and apps/api/.env (api), then fill in.
#
# Every variable here is read by zod at startup; typos fail fast.
# `env.ts` in each app is the canonical schema.

# --- Core ---------------------------------------------------------------

NODE_ENV=development

# Pick a *long* random string. The Express API and the Auth.js web app
# must share this secret — they sign + verify the same HS256 JWT.
#   openssl rand -hex 32
AUTH_SECRET=change-me-to-a-random-32-plus-char-string

# --- Origins ------------------------------------------------------------

# Where the web app runs (used by the API's CORS allowlist).
WEB_ORIGIN=http://localhost:3000

# Where the API runs (used by the web app when it proxies).
API_URL=http://localhost:4000

# Auth.js — callback base. In prod this must match the deployed URL.
AUTH_URL=http://localhost:3000
AUTH_TRUST_HOST=true

# --- Database -----------------------------------------------------------

# API reads MONGO_URI; web reads MONGODB_URI. They can point at the
# same cluster or be isolated — the API is the write authority for
# app data; the web only talks to Mongo for Auth.js session storage.
MONGO_URI=mongodb://localhost:27017/mern-devsuite
MONGODB_URI=mongodb://localhost:27017/mern-devsuite

# --- API behaviour ------------------------------------------------------

PORT=4000
LOG_LEVEL=info

# When true, `/api/gdpr/delete` is a hard purge. Leave false in
# production — the 30-day soft delete exists so a user can cancel a
# mistaken deletion.
GDPR_HARD_DELETE=false

# --- Optional OAuth (wire up providers in apps/web/src/auth.ts) ---------

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# --- Payments (Stripe — optional until you ship billing) ----------------

STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PRO=
STRIPE_PRICE_TEAM=

# --- Observability (optional) -------------------------------------------

OTEL_EXPORTER_OTLP_ENDPOINT=
SENTRY_DSN=

# --- Public, bundled into the web build ---------------------------------

NEXT_PUBLIC_APP_NAME=mern-devsuite
